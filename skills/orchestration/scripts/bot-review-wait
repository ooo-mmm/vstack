#!/usr/bin/env bash
# Wait for bot review(s) to complete on a PR.
#
# Supports multiple bot reviewers with heterogeneous signaling:
#   - Claude-style: formal PR review (APPROVED|CHANGES_REQUESTED) + sticky
#                   "View job" comment with checklist + verdict text.
#   - Codex-style:  reactions on the PR body or earliest comment
#                   (👀 = reviewing, 👍 = approved); inline review threads
#                   when changes are requested.
#
# Usage: bot-review-wait <PR#> [poll_interval] [max_wait]
#                         [--json] [--reviewers "bot1,bot2"] [--skip "bot3,bot4"]
#
# Environment:
#   BOT_REVIEWERS          Comma-separated bot logins to wait for (fallback if
#                          --reviewers not passed). Default: auto-detect.
#   BOT_SKIPPED_REVIEWERS  Comma-separated bot logins to mark as "skipped"
#                          even if they show signal — they will not block
#                          completion. Combined with --skip.
#   BOT_CHECK_NAME         Optional CI check name treated as an early review
#                          completion signal (legacy fast-path for Claude).
#
# Exit codes:
#   0 - All configured reviewers reached a terminal state (approved/changes/skipped)
#   1 - Timeout: at least one reviewer still pending
#   2 - Checklist timeout: terminal verdicts in but bot still posting threads
#
# JSON output (always when --json):
#   {
#     "status": "complete" | "checklist_timeout" | "timeout" | "no_reviewers",
#     "verdict": "approved" | "changes" | "pending",
#     "elapsed_seconds": <int>,
#     "reviewers": [ {reviewer,status,signals,updated_at,unresolved_threads} ... ],
#     "pending_reviewers":  [...],
#     "approved_reviewers": [...],
#     "changes_reviewers":  [...],
#     "skipped_reviewers":  [...]
#   }
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
SKILLS_DIR="$PROJECT_ROOT/.agents/skills"
ENV_FILE="$PROJECT_ROOT/.env.local"
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck source=/dev/null
  source "$ENV_FILE"
fi

GIT_HOST_CLI="${GIT_HOST_CLI:-$SKILLS_DIR/github/scripts/github.sh}"
if [[ ! -x "$GIT_HOST_CLI" ]]; then
  echo "Error: GIT_HOST_CLI not found at '$GIT_HOST_CLI'. Is the github skill installed?" >&2
  exit 1
fi

# Source the github lib for bot_review_status
GH_LIB="$SKILLS_DIR/github/scripts/lib/github-api.sh"
if [[ ! -f "$GH_LIB" ]]; then
  echo "Error: github lib not found at '$GH_LIB'." >&2
  exit 1
fi
# shellcheck source=/dev/null
source "$GH_LIB"

# --- arg parse ---
JSON_OUTPUT=false
REVIEWERS_ARG=""
SKIP_ARG=""
POSITIONAL=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) JSON_OUTPUT=true; shift ;;
    --reviewers) REVIEWERS_ARG="$2"; shift 2 ;;
    --reviewers=*) REVIEWERS_ARG="${1#--reviewers=}"; shift ;;
    --skip) SKIP_ARG="$2"; shift 2 ;;
    --skip=*) SKIP_ARG="${1#--skip=}"; shift ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done

PR_NUM="${POSITIONAL[0]:?Usage: bot-review-wait <PR#> [poll_interval] [max_wait] [--json] [--reviewers \"bot1,bot2\"] [--skip \"bot3,bot4\"]}"
POLL_INTERVAL="${POSITIONAL[1]:-15}"
MAX_WAIT="${POSITIONAL[2]:-600}"

# --- skipped set ---
declare -A SKIPPED=()
for s in $(printf '%s' "${SKIP_ARG:-${BOT_SKIPPED_REVIEWERS:-}}" | tr ',' ' '); do
  [[ -n "$s" ]] && SKIPPED["$s"]=1
done

# --- reviewer set ---
REVIEWERS=()
if [[ -n "$REVIEWERS_ARG" ]]; then
  IFS=',' read -ra REVIEWERS <<< "$REVIEWERS_ARG"
elif [[ -n "${BOT_REVIEWERS:-}" ]]; then
  IFS=',' read -ra REVIEWERS <<< "$BOT_REVIEWERS"
else
  while IFS= read -r bot; do
    [[ -n "$bot" ]] && REVIEWERS+=("$bot")
  done < <(detect_bot_reviewers "$PR_NUM" 2>/dev/null || true)
fi

# Trim whitespace from reviewer entries.
trimmed=()
for r in "${REVIEWERS[@]:-}"; do
  r="${r#"${r%%[![:space:]]*}"}"
  r="${r%"${r##*[![:space:]]}"}"
  [[ -n "$r" ]] && trimmed+=("$r")
done
REVIEWERS=("${trimmed[@]}")

PHASE3_MAX=300       # Sticky-checklist wait after terminal verdict
PHASE3_INTERVAL=10
elapsed=0

# Per-iteration: collect all reviewers' status into a JSON array.
collect_reviewers() {
  local arr='[]'
  for r in "${REVIEWERS[@]}"; do
    local entry
    entry=$(bot_review_status "$PR_NUM" "$r" 2>/dev/null || \
            jq -n -c --arg u "$r" '{reviewer:$u,status:"unknown",signals:[],updated_at:"",unresolved_threads:0}')
    if [[ -n "${SKIPPED[$r]:-}" ]]; then
      entry=$(jq -c '.status = "skipped" | .signals += ["config:skipped"]' <<<"$entry")
    fi
    arr=$(jq -c --argjson e "$entry" '. + [$e]' <<<"$arr")
  done
  printf '%s' "$arr"
}

# Bucket reviewer logins by status; aggregate verdict.
# Echoes 5 newline-separated JSON arrays + verdict on a final line:
#   pending\napproved\nchanges\nskipped\nunknown\nverdict
bucket_reviewers() {
  local entries="$1"
  jq -r '
    {
      pending:  [.[] | select(.status == "pending")  | .reviewer],
      approved: [.[] | select(.status == "approved") | .reviewer],
      changes:  [.[] | select(.status == "changes")  | .reviewer],
      skipped:  [.[] | select(.status == "skipped")  | .reviewer],
      unknown:  [.[] | select(.status == "unknown")  | .reviewer]
    } |
    (.pending  | tojson),
    (.approved | tojson),
    (.changes  | tojson),
    (.skipped  | tojson),
    (.unknown  | tojson)
  ' <<<"$entries"
}

# Combine per-reviewer statuses into a single verdict for legacy callers.
# Precedence: changes > pending > approved > unknown.
# "skipped" reviewers are excluded from verdict aggregation.
aggregate_verdict() {
  local entries="$1"
  jq -r '
    [.[] | select(.status != "skipped")] as $effective |
    if   ($effective | any(.status == "changes"))  then "changes"
    elif ($effective | any(.status == "pending"))  then "pending"
    elif ($effective | any(.status == "unknown") and ($effective | all(.status != "approved"))) then "pending"
    elif ($effective | any(.status == "approved")) then "approved"
    else "pending" end
  ' <<<"$entries"
}

# A reviewer is "blocking" if status is unknown or pending — i.e. we cannot
# yet say it has reached a terminal state.
any_blocking() {
  local entries="$1"
  local n
  n=$(jq '[.[] | select(.status == "pending" or .status == "unknown")] | length' <<<"$entries")
  [[ "$n" -gt 0 ]]
}

# Sticky-checklist done check (still uses GIT_HOST_CLI for the default
# Claude-style sticky bot — this only matters for that bot's path).
sticky_checklist_done() {
  local body
  body=$("$GIT_HOST_CLI" sticky-comment "$PR_NUM" --body 2>/dev/null || echo "")
  [[ -z "$body" ]] && return 0
  local unchecked
  unchecked=$(printf '%s\n' "$body" | grep -c '^[[:space:]]*- \[ \]' || true)
  [[ "$unchecked" -eq 0 ]]
}

# Wait up to PHASE3_MAX (capped by remaining MAX_WAIT) for the sticky
# checklist to drain after a terminal verdict has arrived.
# Returns 0 if drained, 1 on timeout. Updates global $elapsed.
wait_for_checklist() {
  local p3_elapsed=0
  local remaining=$((MAX_WAIT - elapsed))
  local p3_max=$PHASE3_MAX
  [[ $p3_max -gt $remaining ]] && p3_max=$remaining
  while [ $p3_elapsed -lt $p3_max ]; do
    if sticky_checklist_done; then
      return 0
    fi
    if ! $JSON_OUTPUT; then
      echo "Waiting for bot to finish posting threads..." >&2
    fi
    sleep "$PHASE3_INTERVAL"
    p3_elapsed=$((p3_elapsed + PHASE3_INTERVAL))
    elapsed=$((elapsed + PHASE3_INTERVAL))
  done
  sticky_checklist_done
}

emit_result() {
  local status="$1"
  local entries="$2"
  local verdict
  verdict=$(aggregate_verdict "$entries")

  local pending_arr approved_arr changes_arr skipped_arr unknown_arr
  {
    read -r pending_arr
    read -r approved_arr
    read -r changes_arr
    read -r skipped_arr
    read -r unknown_arr
  } < <(bucket_reviewers "$entries")

  if $JSON_OUTPUT; then
    jq -n \
      --arg s "$status" \
      --arg v "$verdict" \
      --argjson elapsed "$elapsed" \
      --argjson reviewers "$entries" \
      --argjson pending  "$pending_arr" \
      --argjson approved "$approved_arr" \
      --argjson changes  "$changes_arr" \
      --argjson skipped  "$skipped_arr" \
      --argjson unknown  "$unknown_arr" \
      '{
        status: $s,
        verdict: $v,
        elapsed_seconds: $elapsed,
        reviewers: $reviewers,
        pending_reviewers:  $pending  + $unknown,
        approved_reviewers: $approved,
        changes_reviewers:  $changes,
        skipped_reviewers:  $skipped
      }'
  else
    case "$status" in
      complete)
        echo "Bot reviews complete (verdict: $verdict; reviewers: ${REVIEWERS[*]:-none})" >&2 ;;
      checklist_timeout)
        echo "Bot review verdict received (${verdict}) but checklist still pending after ${PHASE3_MAX}s." >&2 ;;
      timeout)
        echo "Bot review timeout after ${MAX_WAIT}s (verdict: $verdict; pending: $pending_arr)" >&2 ;;
      no_reviewers)
        echo "No bot reviewers detected on PR #$PR_NUM — returning unknown." >&2 ;;
    esac
  fi
}

# --- Edge case: no reviewers at all ---
if [[ ${#REVIEWERS[@]} -eq 0 ]]; then
  emit_result "no_reviewers" "[]"
  exit 0
fi

# --- BOT_CHECK_NAME fast-path (legacy Claude CI signal) ---
PHASE1_MAX=60
phase1_end=$((elapsed + PHASE1_MAX))
[[ $phase1_end -gt $MAX_WAIT ]] && phase1_end=$MAX_WAIT
BOT_CHECK_NAME="${BOT_CHECK_NAME:-}"

while [ $elapsed -lt $phase1_end ] && [[ -n "$BOT_CHECK_NAME" ]]; do
  check_lines=""
  check_lines=$(gh pr checks "$PR_NUM" 2>&1 | grep -E "^\s*${BOT_CHECK_NAME}\s" || true)
  if [ -n "$check_lines" ]; then
    if echo "$check_lines" | grep -qE '\b(pass|fail)\b'; then
      entries=$(collect_reviewers)
      if ! any_blocking "$entries"; then
        if wait_for_checklist; then
          emit_result "complete" "$entries"
          exit 0
        else
          emit_result "checklist_timeout" "$entries"
          exit 2
        fi
      fi
    elif ! echo "$check_lines" | grep -qE '\bpending\b'; then
      # All skipping → bot won't run (CI-side decision). Treat as no signal —
      # fall through to the per-reviewer poll loop.
      break
    fi
  fi
  sleep "$POLL_INTERVAL"
  elapsed=$((elapsed + POLL_INTERVAL))
done

# --- Main poll loop: per-reviewer status until all terminal or timeout ---
while [ $elapsed -lt $MAX_WAIT ]; do
  entries=$(collect_reviewers)
  if ! any_blocking "$entries"; then
    if wait_for_checklist; then
      emit_result "complete" "$entries"
      exit 0
    else
      # Refresh entries — the checklist wait can take minutes; reviewers
      # may have updated their state in the meantime.
      entries=$(collect_reviewers)
      if any_blocking "$entries"; then
        # Something regressed to pending while we waited on the checklist.
        # Continue the main loop to re-evaluate.
        continue
      fi
      emit_result "checklist_timeout" "$entries"
      exit 2
    fi
  fi
  sleep "$POLL_INTERVAL"
  elapsed=$((elapsed + POLL_INTERVAL))
done

# --- Timeout: one final read ---
entries=$(collect_reviewers)
if ! any_blocking "$entries"; then
  # Crossed the line right at the bell.
  if wait_for_checklist; then
    emit_result "complete" "$entries"
    exit 0
  fi
  emit_result "checklist_timeout" "$entries"
  exit 2
fi
emit_result "timeout" "$entries"
exit 1
